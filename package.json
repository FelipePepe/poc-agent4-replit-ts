{
  "name": "poc-agent4-replit-ts",
  "version": "0.1.0",
  "description": "PoC Replit Agent 4 clone — TypeScript / LangGraph.js / Express",
  "main": "dist/core/api.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/core/api.js",
    "dev": "tsx src/core/api.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.ts' 'tests/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "dependencies": {
    "@langchain/anthropic": "^0.3.0",
    "@langchain/core": "^0.3.0",
    "@langchain/langgraph": "^0.2.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "coverageDirectory": "coverage",
    "coverageThreshold": {
      "global": {
        "lines": 99
      }
    },
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/index.ts"
    ]
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
