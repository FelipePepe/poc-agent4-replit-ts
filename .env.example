# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# GitHub OAuth token for Copilot API access.
# Local dev:   leave empty — token is resolved automatically via `gh auth token`
#              (requires: gh auth login)
# Production:  set this to the OAuth token obtained from your OAuth callback.
GITHUB_OAUTH_TOKEN=

LANGSMITH_API_KEY=
LANGSMITH_PROJECT=poc-agent4-ts
NODE_ENV=development
PORT=3000

# Optional: enable Ollama LLM classifier (phi3:mini)
# OLLAMA_BASE_URL=http://localhost:11434
